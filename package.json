{
  "name": "pinz-bowling-league",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "sync": "node sync.js",

    "recap:parse": "node scripts/parse-recap-pdf.js",
    "validate:week": "node scripts/validate-weekly-history.js",
    "merge": "node scripts/merge-bowler-history.js",
    "validate:history": "node scripts/validate-bowler-history.js",

    "report": "node scripts/report-bowler-history.js",
    "report:tops": "node scripts/report-top-game-scores.js",

    "week": "npm run sync && npm run validate:week --",
    "week:merge": "npm run merge -- && npm run validate:history",
    "week:full": "npm run sync && npm run validate:week -- && npm run merge -- && npm run validate:history",

    "week:from-recap": "npm run recap:parse -- && npm run validate:week --",
    "week:rebuild": "npm run recap:parse -- && npm run validate:week -- && npm run merge -- && npm run validate:history",

    "week:auto": "node scripts/week-auto.js",
    "week:diff": "node scripts/diff-week.js"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  }
}
